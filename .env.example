# Demo mode — API key gerektirmez, fake providers kullanır
# UI ve RAG akışını test etmek için: USE_MOCK_PROVIDERS=true yapın
# Gerçek LLM cevapları için: false (veya bu satırı boş bırakın) + GEMINI_API_KEY ekleyin
USE_MOCK_PROVIDERS=false

# LLM (USE_MOCK_PROVIDERS=false ise zorunlu)
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-key-here
GEMINI_LLM_MODEL=gemini-2.5-flash

# Embedding
EMBEDDING_PROVIDER=gemini
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Vector store
VECTOR_STORE=chroma
CHROMA_PATH=./data/chroma_db

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:8501
MAX_UPLOAD_MB=50

# Retrieval
DEFAULT_TOP_K=4

# Frontend
BACKEND_URL=http://localhost:8000
